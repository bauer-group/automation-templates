# Normalize all text files to LF in the repository.
# Prevents the mixed CRLF/LF state that produced noisy diffs.
* text=auto eol=lf

# Explicit LF (defensive — same as the default above)
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.py        text eol=lf
*.sh        text eol=lf
*.txt       text eol=lf
*.xml       text eol=lf
*.toml      text eol=lf
*.neon      text eol=lf
*.js        text eol=lf
*.php       text eol=lf
*.service   text eol=lf
*.example   text eol=lf
.gitignore      text eol=lf
.gitattributes  text eol=lf
Dockerfile      text eol=lf

# Windows-native scripts must keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
*.psm1      text eol=crlf

# Binary files — never diffed or line-ending normalized
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.jar       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.exe       binary
*.dll       binary
